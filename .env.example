# Shared
NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openlobby
JWT_ACCESS_SECRET=replace-with-a-secure-random-value
JWT_REFRESH_SECRET=replace-with-a-secure-random-value
AZURE_STORAGE_CONNECTION_STRING=replace-with-azure-storage-connection-string
AZURE_STORAGE_CONTAINER=openlobby-media
REDIS_URL=redis://localhost:6379
RESEND_API_KEY=replace-with-resend-api-key
